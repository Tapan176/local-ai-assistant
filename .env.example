TAPAN_LLM_PROVIDER=mock
TAPAN_SQLITE_PATH=data/tapan_ai_v2.db
TAPAN_CHROMA_PATH=data/chroma_v2
TAPAN_API_HOST=127.0.0.1
TAPAN_API_PORT=8000
TAPAN_LOG_LEVEL=INFO
TAPAN_INTENT_CLASSIFIER=hybrid
TAPAN_SEMANTIC_INTENT_MODEL=sentence-transformers/all-MiniLM-L6-v2
TAPAN_SEMANTIC_INTENT_THRESHOLD=0.62
TAPAN_SPACY_MODEL=en_core_web_sm

# BitNet (set TAPAN_BITNET_ENABLED=true to activate)
TAPAN_BITNET_ENABLED=false
TAPAN_BITNET_MODE=auto
TAPAN_BITNET_URL=http://localhost:8001
TAPAN_BITNET_MODEL=bitnet-7b
TAPAN_BITNET_TIMEOUT=60

# bitnet.cpp local fallback
# Example Windows executable:
# TAPAN_BITNET_CPP_EXECUTABLE=C:\\models\\bitnet.cpp\\build\\bin\\Release\\llama-cli.exe
# TAPAN_BITNET_CPP_MODEL_PATH=C:\\models\\bitnet-7b-q4.gguf
TAPAN_BITNET_CPP_EXECUTABLE=
TAPAN_BITNET_CPP_MODEL_PATH=
TAPAN_BITNET_CPP_MAX_TOKENS=256
TAPAN_BITNET_CPP_THREADS=0
TAPAN_BITNET_CPP_CTX_SIZE=0
TAPAN_BITNET_CPP_EXTRA_ARGS=
