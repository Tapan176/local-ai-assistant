# ── OpenRouter (Primary Cloud LLM) ──────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key-here
TAPAN_OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
TAPAN_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
TAPAN_OPENROUTER_FALLBACK_MODEL=google/gemma-3-27b-it:free
TAPAN_OPENROUTER_TIMEOUT=60

# ── Supermemory (Unified Memory) ────────────────────────────────
TAPAN_SUPERMEMORY_API_KEY=your-supermemory-api-key-here

# ── LLM Provider Priority: openrouter → ollama → bitnet ────────
TAPAN_LLM_PROVIDER=openrouter

# ── Ollama (Fallback - optional, if running locally) ────────────
# TAPAN_OLLAMA_URL=http://localhost:11434/api/chat
# TAPAN_OLLAMA_MODEL=qwen2.5:7b
